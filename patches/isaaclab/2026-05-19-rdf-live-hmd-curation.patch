+        retargeters.append(GripperRetargeterCfg(bound_hand=DeviceBase.TrackingTarget.HAND_RIGHT, sim_device=env_cfg.sim.device))
+    return DevicesCfg(
+        devices={
+            "handtracking": OpenXRDeviceCfg(
+                retargeters=retargeters,
+                sim_device=env_cfg.sim.device,
+                xr_cfg=default_xr_cfg(env_cfg),
+            )
+        }
+    )
