+class RdfXrTaskGuidanceWidget:
+    """HMD-readable XR text widget for no-keyboard collection guidance."""
+
+    def __init__(self, scale: float, source_prim_path: str, translation: tuple[float, float, float]):
+        import omni.kit.commands
+        from omni import ui
+        from omni.kit.xr.scene_view.utils import UiContainer, WidgetComponent
+        from omni.kit.xr.scene_view.utils.spatial_source import SpatialSource
+        from pxr import Gf
+        import isaaclab.sim as sim_utils
+        import omni.usd
+
+        class _RdfGuidanceTextWidget(ui.Widget):
+            def __init__(
+                self,
+                text: str,
+                font_size: float,
+                text_color: int,
+                background_color: int,
+                **kwargs,
+            ):
+                super().__init__(**kwargs)
+                self._font_size = font_size
+                self._text = text
+                self._text_color = text_color
+                self._background_color = background_color
+                self._label = None
+                self._background = None
+                self._build_ui()
+
+            def _label_style(self) -> dict:
+                return {"font_size": self._font_size, "color": self._text_color}
+
+            def _background_style(self) -> dict:
+                return {"Rectangle": {"background_color": self._background_color, "border_radius": 0.1}}
+
+            def _build_ui(self) -> None:
+                with ui.ZStack():
+                    self._background = ui.Rectangle(style=self._background_style())
+                    with ui.VStack(alignment=ui.Alignment.CENTER):
+                        self._label = ui.Label(
+                            self._text,
+                            style=self._label_style(),
+                            alignment=ui.Alignment.CENTER,
+                        )
+
+            def set_state(self, text: str, text_color: int, background_color: int) -> None:
+                self._text = text
+                self._text_color = text_color
+                self._background_color = background_color
+                if self._label is not None:
+                    self._label.text = self._text
+                    self._label.style = self._label_style()
+                if self._background is not None:
+                    self._background.style = self._background_style()
+
+        self._omni_kit_commands = omni.kit.commands
+        self._UiContainer = UiContainer
+        self._WidgetComponent = WidgetComponent
+        self._SpatialSource = SpatialSource
+        self._GuidanceTextWidget = _RdfGuidanceTextWidget
+        self._sim_utils = sim_utils
+        self._gf = Gf
+        self._stage = omni.usd.get_context().get_stage()
+        self._source_prim_path = source_prim_path.strip() if source_prim_path else ""
+        self._translation = self._gf.Vec3f(float(translation[0]), float(translation[1]), float(translation[2]))
+        self._target_prim_path = "/RDFTaskGuidanceWidget"
+        self._container = None
+        self._widget_component = None
+        self._text_widget = None
+        self._last_text = None
+        self._last_color_state = None
+        self._widget_created = False
+        self._waiting_logged = False
+        self._font_size = 0.13 * max(0.75, float(scale))
+        self._max_width = 2.65 * max(0.75, float(scale))
+        self._height = 0.74 * max(0.75, float(scale))
+        self._text_color = 0xFFFFFFFF
+        self._neutral_background_color = 0xFF454545
+        self._not_ready_background_color = 0xFF5A1D1D
+        self._holding_background_color = 0xFF7A240F
+        self._ready_background_color = 0xFF0B5A28
+        self._create_widget("RDF TELEOP\nWAITING FOR HAND TRACKING", "neutral")
+
+    def _source_ready(self) -> bool:
+        if not self._source_prim_path:
+            return True
+        try:
+            return bool(self._stage.GetPrimAtPath(self._source_prim_path).IsValid())
+        except Exception:
+            return False
+
+    def _component_tint(self, color_state: str) -> list[float]:
+        if color_state == "ready":
+            return [0.18, 1.0, 0.32, 1.0]
+        if color_state == "holding":
+            return [1.0, 0.18, 0.12, 1.0]
+        if color_state == "not_ready":
+            return [1.0, 0.08, 0.06, 1.0]
+        return [1.0, 1.0, 1.0, 1.0]
+
+    def _background_color_for_state(self, color_state: str) -> int:
+        if color_state == "ready":
+            return self._ready_background_color
+        if color_state == "holding":
+            return self._holding_background_color
+        if color_state == "not_ready":
+            return self._not_ready_background_color
+        return self._neutral_background_color
+
+    def _capture_widget(self, widget) -> None:
+        self._text_widget = widget
+        if self._last_text is not None:
+            widget.set_state(
+                self._last_text,
+                self._text_color,
+                self._background_color_for_state(self._last_color_state or "neutral"),
+            )
+
+    def _create_widget(self, text: str, color_state: str) -> bool:
+        if not self._source_ready():
+            if not self._waiting_logged:
+                print(
+                    "[RDF] HMD task guidance widget waiting for XR source prim: "
+                    f"{self._source_prim_path}"
+                )
+                self._waiting_logged = True
+            return False
+
+        if self._stage.GetPrimAtPath(self._target_prim_path).IsValid():
+            self._sim_utils.delete_prim(self._target_prim_path, stage=self._stage)
+
+        if self._source_prim_path:
+            self._omni_kit_commands.execute(
+                "CopyPrim",
+                path_from=self._source_prim_path,
+                path_to=self._target_prim_path,
+                exclusive_select=False,
+                copy_to_introducing_layer=False,
+            )
+        else:
+            from pxr import UsdGeom
+
+            UsdGeom.Xform.Define(self._stage, self._target_prim_path)
+
+        space_stack = [
+            self._SpatialSource.new_prim_path_source(self._target_prim_path),
+            self._SpatialSource.new_translation_source(self._translation),
+        ]
+        self._widget_component = self._WidgetComponent(
+            self._GuidanceTextWidget,
+            width=self._max_width,
+            height=self._height,
+            resolution_scale=300,
+            construct_callback=self._capture_widget,
+            widget_args=[
+                text,
+                self._font_size,
+                self._text_color,
+                self._background_color_for_state(color_state),
+            ],
+            color=self._component_tint(color_state),
+        )
+        self._container = self._UiContainer(self._widget_component, space_stack=space_stack)
+        container = self._container
+        if container is None:
+            logger.warning(
+                "[RDF] HMD task guidance widget create returned None: "
+                f"source={self._source_prim_path or 'world'} target={self._target_prim_path}"
+            )
+            return False
+        if not self._widget_created:
+            print(
+                "[RDF] HMD task guidance widget created: "
+                f"source={self._source_prim_path or 'world'} "
+                f"translation={[round(float(self._translation[i]), 3) for i in range(3)]} "
+                f"target={self._target_prim_path} rotation_mode=fixed"
+            )
+        self._widget_created = True
+        self._last_text = text
+        self._last_color_state = color_state
+        return True
+
+    def _set_widget_state(self, text: str, color_state: str) -> bool:
+        if self._text_widget is None:
+            return False
+        self._text_widget.set_state(text, self._text_color, self._background_color_for_state(color_state))
+        if self._widget_component is not None:
+            self._widget_component.color = self._component_tint(color_state)
+            if self._widget_component.scene_widget is not None:
+                self._widget_component.scene_widget.invalidate()
+        self._last_text = text
+        self._last_color_state = color_state
+        return True
+
+    def update(self, *, recentered: bool, status: dict | None) -> None:
+        status = status or {}
+        status_name = str(status.get("status") or "UNKNOWN")
+        phase = str(status.get("phase") or "UNKNOWN")
+        success_ready = bool(status.get("success_ready"))
+        auto_finalize_ready = bool(status.get("auto_finalize_ready")) or status_name == "AUTO_FINALIZE_READY"
+        hold_elapsed = float(status.get("hold_elapsed_sec") or 0.0)
+        hold_required = float(status.get("hold_required_sec") or 0.0)
+        hold_remaining = max(0.0, hold_required - hold_elapsed)
+        live_required = bool(status.get("live_curation_required"))
+        live_curation = status.get("live_curation") if isinstance(status.get("live_curation"), dict) else {}
+        live_reasons = list(status.get("live_curation_reasons") or live_curation.get("reasons") or [])
+        live_reason = live_reasons[0] if live_reasons else ""
+        if len(live_reason) > 34:
+            live_reason = live_reason[:31] + "..."
+
+        recenter_line = "RECENTER: OK" if recentered else "RECENTER: HOLD HAND STILL"
+        success_line = "SUCCESS_READY: YES" if success_ready else "SUCCESS_READY: NO"
+        if live_required and status_name == "LIVE_CURATED_READY":
+            state_line = "LIVE_CURATED: READY"
+        elif live_required and status_name == "LIVE_CURATION_FAILED":
+            state_line = f"CURATION FAIL: {live_reason or 'QUALITY'}"
+        elif live_required and status_name == "LIVE_CURATION_PENDING":
+            state_line = f"CURATION WAIT: {live_reason or 'QUALITY'}"
+        elif auto_finalize_ready:
+            state_line = "AUTO_FINALIZE: READY"
+        elif success_ready:
+            state_line = f"HOLD: {hold_elapsed:.1f}/{hold_required:.1f}s"
+        elif status_name == "UNKNOWN":
+            state_line = "TASK STATE: WAITING"
+        else:
+            state_line = f"PHASE: {phase}"
+
+        gates = []
+        distance_label = "LAT" if status.get("peg_distance_metric") == "lateral_projection" else "DIST"
+        for label, key in ((distance_label, "distance_ok"), ("ALIGN", "alignment_ok"), ("DEPTH", "depth_ok")):
+            value = status.get(key)
+            if value is True:
+                gates.append(f"{label}:OK")
+            elif value is False:
+                gates.append(f"{label}:--")
+        gate_line = "  ".join(gates) if gates else "MOVE PEG INTO TARGET"
+        if live_required:
+            live_status = str(status.get("live_curation_status") or live_curation.get("status") or "pending").upper()
+            if len(live_status) > 12:
+                live_status = live_status[:12]
+            gate_line = f"{gate_line}  LIVE:{live_status}"
+
+        if hold_required > 0:
+            progress_count = int(round(_rdf_clamp01(hold_elapsed / hold_required) * 10.0))
+            progress_line = "[" + "#" * progress_count + "." * (10 - progress_count) + f"] {hold_remaining:.1f}s"
+        else:
+            progress_line = "[..........]"
+
+        text = "\n".join((success_line, recenter_line, state_line, gate_line, progress_line))
+        if status_name == "LIVE_CURATION_FAILED":
+            color_state = "not_ready"
+        elif auto_finalize_ready:
+            color_state = "ready"
+        elif success_ready:
+            color_state = "holding"
+        elif status_name == "UNKNOWN":
+            color_state = "neutral"
+        else:
+            color_state = "not_ready"
+
+        if not self._widget_created:
+            self._create_widget(text, color_state)
+            return
+        if text == self._last_text and color_state == self._last_color_state:
+            return
+        if not self._set_widget_state(text, color_state):
+            logger.warning("[RDF] HMD task guidance widget update missed; waiting for widget construction")
+
+
+class RdfUsdTaskGuidancePanel:
+    """Minimal in-world status panel visible in HMD without terminal access."""
+
+    def __init__(self, scale: float):
+        from pxr import Gf, Sdf, UsdGeom
+        import omni.usd
+
+        self._gf = Gf
+        self._stage = omni.usd.get_context().get_stage()
+        self._usd_geom = UsdGeom
+        self._scale = max(0.5, float(scale))
+        self._elements = {}
+
+        root_path = Sdf.Path("/World/RDFTaskGuidancePanel")
+        if not self._stage.GetPrimAtPath(root_path):
+            UsdGeom.Xform.Define(self._stage, root_path)
+
+        self._make_sphere(root_path, "recenter", (0.20, 0.20, 0.20), 0.026)
+        self._make_sphere(root_path, "success", (0.90, 0.55, 0.05), 0.034)
+        self._make_sphere(root_path, "finalize", (0.20, 0.20, 0.20), 0.026)
+        self._make_cube(root_path, "progress_bg", (0.10, 0.10, 0.10))
+        self._make_cube(root_path, "progress_fill", (0.0, 0.85, 0.20))
+
+    def _make_sphere(self, root_path, name: str, color: tuple[float, float, float], radius: float) -> None:
+        sphere = self._usd_geom.Sphere.Define(self._stage, f"{root_path.pathString}/{name}")
+        sphere.CreateRadiusAttr(radius * self._scale)
+        color_attr = sphere.CreateDisplayColorAttr([color])
+        xformable = self._usd_geom.Xformable(sphere.GetPrim())
+        self._elements[name] = {
+            "translate": xformable.AddTranslateOp(),
+            "color": color_attr,
+        }
+
+    def _make_cube(self, root_path, name: str, color: tuple[float, float, float]) -> None:
+        cube = self._usd_geom.Cube.Define(self._stage, f"{root_path.pathString}/{name}")
+        cube.CreateSizeAttr(1.0)
+        color_attr = cube.CreateDisplayColorAttr([color])
+        xformable = self._usd_geom.Xformable(cube.GetPrim())
+        self._elements[name] = {
+            "translate": xformable.AddTranslateOp(),
+            "scale": xformable.AddScaleOp(),
+            "color": color_attr,
+        }
+
+    def _set_sphere(self, name: str, position: list[float], color: tuple[float, float, float]) -> None:
+        element = self._elements[name]
+        element["translate"].Set(self._gf.Vec3d(float(position[0]), float(position[1]), float(position[2])))
+        element["color"].Set([color])
+
+    def _set_cube(
+        self,
+        name: str,
+        position: list[float],
+        scale: tuple[float, float, float],
+        color: tuple[float, float, float],
+    ) -> None:
+        element = self._elements[name]
+        element["translate"].Set(self._gf.Vec3d(float(position[0]), float(position[1]), float(position[2])))
+        element["scale"].Set(self._gf.Vec3f(float(scale[0]), float(scale[1]), float(scale[2])))
+        element["color"].Set([color])
+
+    def _anchor(self, env) -> list[float] | None:
+        try:
+            refresh_intermediate_values(env)
+        except Exception:
+            pass
+        fixed_pos = getattr(env, "fixed_pos_obs_frame", None)
+        fixed_noise = getattr(env, "init_fixed_pos_obs_noise", None)
+        if fixed_pos is not None and fixed_noise is not None:
+            try:
+                return tensor_xyz_to_list((fixed_pos + fixed_noise)[0])
+            except Exception:
+                pass
+        for attr in ("fixed_pos", "fingertip_midpoint_pos"):
+            value = getattr(env, attr, None)
+            if value is None:
+                continue
+            try:
+                return tensor_xyz_to_list(value[0])
+            except Exception:
+                continue
+        return None
+
+    def update(self, env, *, recentered: bool, status: dict | None) -> None:
+        anchor = self._anchor(env)
+        if anchor is None:
+            return
+        panel_scale = self._scale
+        base = [
+            float(anchor[0]),
+            float(anchor[1]) - 0.24 * panel_scale,
+            float(anchor[2]) + 0.22 * panel_scale,
+        ]
+
+        status = status or {}
+        status_name = str(status.get("status") or "UNKNOWN")
+        success_ready = bool(status.get("success_ready"))
+        auto_finalize_ready = bool(status.get("auto_finalize_ready")) or status_name == "AUTO_FINALIZE_READY"
+        hold_required = float(status.get("hold_required_sec") or 0.0)
+        hold_elapsed = float(status.get("hold_elapsed_sec") or 0.0)
+        progress = _rdf_clamp01(hold_elapsed / hold_required) if hold_required > 0 else 0.0
+
+        recenter_color = (0.0, 0.65, 1.0) if recentered else (0.20, 0.20, 0.20)
+        if status_name == "UNKNOWN":
+            success_color = (0.35, 0.35, 0.35)
+        elif status_name == "LIVE_CURATION_FAILED":
+            success_color = (1.0, 0.08, 0.04)
+        elif auto_finalize_ready:
+            success_color = (0.0, 1.0, 0.15)
+        elif success_ready:
+            success_color = (0.0, 0.90, 0.20)
+        else:
+            success_color = (0.95, 0.60, 0.05)
+        finalize_color = (1.0, 1.0, 1.0) if auto_finalize_ready else (0.20, 0.20, 0.20)
+        fill_color = (1.0, 0.08, 0.04) if status_name == "LIVE_CURATION_FAILED" else (0.0, 1.0, 0.20) if success_ready else (0.30, 0.30, 0.30)
+
+        self._set_sphere(
+            "recenter",
+            [base[0] - 0.09 * panel_scale, base[1], base[2]],
+            recenter_color,
+        )
+        self._set_sphere("success", base, success_color)
+        self._set_sphere(
+            "finalize",
+            [base[0] + 0.09 * panel_scale, base[1], base[2]],
+            finalize_color,
+        )
+
+        bar_width = 0.18 * panel_scale
+        bar_height = 0.012 * panel_scale
+        bar_depth = 0.010 * panel_scale
+        bar_z = base[2] - 0.055 * panel_scale
+        self._set_cube(
+            "progress_bg",
+            [base[0], base[1], bar_z],
+            (bar_width, bar_depth, bar_height),
+            (0.10, 0.10, 0.10),
+        )
+        fill_width = max(0.004 * panel_scale, bar_width * progress)
+        fill_center_x = base[0] - (bar_width - fill_width) / 2.0
+        self._set_cube(
+            "progress_fill",
+            [fill_center_x, base[1] - 0.002 * panel_scale, bar_z],
+            (fill_width, bar_depth * 1.3, bar_height * 1.3),
+            fill_color,
+        )
+
+
+def initialize_rdf_task_guidance_panel(
+    enabled: bool,
+    scale: float,
+    primitive_fallback: bool = False,
+    source_prim_path: str = "/_xr/stage/xrCamera",
+    translation: tuple[float, float, float] = (0.0, 0.30, -2.0),
+):
+    if not enabled or getattr(args_cli, "headless", False):
+        return None
+    try:
+        return RdfXrTaskGuidanceWidget(scale, source_prim_path, translation)
+    except Exception as widget_exc:
+        logger.warning(f"[RDF] XR text guidance widget unavailable: {widget_exc}")
+    if not primitive_fallback:
+        return None
+    try:
+        return RdfUsdTaskGuidancePanel(scale)
+    except Exception as exc:
+        logger.warning(f"[RDF] Primitive task guidance panel disabled: {exc}")
+        return None
+
