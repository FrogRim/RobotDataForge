+def start_rdf_terminal_hotkeys(callbacks: dict[str, Callable[[], None]]) -> Callable[[], None] | None:
+    """Listen for RDF lifecycle hotkeys from the launching terminal.
+
+    OpenXR hand tracking receives gesture messages, not keyboard events. During
+    live collection, operators often keep focus on the terminal or headset view,
+    so P/N/F/R must also be accepted from stdin when available.
+    """
+
+    if not sys.stdin.isatty():
+        print("[RDF] Terminal hotkeys disabled: stdin is not a TTY")
+        return None
+
+    try:
+        import select
+        import termios
+        import tty
+    except Exception as exc:
+        print(f"[RDF] Terminal hotkeys disabled: {exc}")
+        return None
+
+    fd = sys.stdin.fileno()
+    try:
+        old_attrs = termios.tcgetattr(fd)
+        tty.setcbreak(fd)
+        new_attrs = termios.tcgetattr(fd)
+        new_attrs[3] = new_attrs[3] & ~termios.ECHO
+        termios.tcsetattr(fd, termios.TCSADRAIN, new_attrs)
+    except Exception as exc:
+        print(f"[RDF] Terminal hotkeys disabled: failed to configure terminal: {exc}")
+        return None
+
+    stop_event = threading.Event()
+
+    def restore_terminal() -> None:
+        stop_event.set()
+        try:
+            termios.tcsetattr(fd, termios.TCSADRAIN, old_attrs)
+        except Exception:
+            pass
+
+    def reader_loop() -> None:
+        while not stop_event.is_set():
+            try:
+                readable, _, _ = select.select([sys.stdin], [], [], 0.1)
+                if not readable:
+                    continue
+                key = sys.stdin.read(1).upper()
+            except Exception:
+                break
+            if key in callbacks:
+                callbacks[key]()
+
+    thread = threading.Thread(target=reader_loop, name="rdf-terminal-hotkeys", daemon=True)
+    thread.start()
+    print("[RDF] Terminal hotkeys active: P=recenter, N=success, F=failure, R=reset")
+    return restore_terminal


