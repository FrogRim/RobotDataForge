+def apply_live_curation_to_task_status(status: dict | None, live_curation: dict | None, *, required: bool) -> dict | None:
+    if status is None:
+        return None
+    merged = dict(status)
+    merged["live_curation_required"] = bool(required)
+    if live_curation is None:
+        if required and merged.get("auto_finalize_ready"):
+            merged["task_auto_finalize_ready"] = True
+            merged["auto_finalize_ready"] = False
+            merged["status"] = "LIVE_CURATION_PENDING"
+            merged["live_curation_ready"] = False
+            merged["live_curation_status"] = "pending"
+            merged["live_curation_reasons"] = ["LIVE_CURATION:UNAVAILABLE"]
+        return merged
+    merged["live_curation"] = live_curation
+    merged["live_curation_ready"] = bool(live_curation.get("ready"))
+    merged["live_curation_status"] = live_curation.get("status")
+    merged["live_curation_reasons"] = list(live_curation.get("reasons") or [])
+    if not required:
+        return merged
+
+    task_auto_finalize_ready = bool(merged.get("auto_finalize_ready"))
+    merged["task_auto_finalize_ready"] = task_auto_finalize_ready
+    if not task_auto_finalize_ready:
+        return merged
+    if live_curation.get("ready"):
+        merged["status"] = "LIVE_CURATED_READY"
+        merged["auto_finalize_ready"] = True
+        return merged
+
+    merged["auto_finalize_ready"] = False
+    merged["status"] = "LIVE_CURATION_FAILED" if live_curation.get("hard_fail") else "LIVE_CURATION_PENDING"
