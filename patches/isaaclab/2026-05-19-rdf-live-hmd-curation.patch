+def initialize_rdf_visual_debug(enabled: bool, point_size: float):
+    if not enabled or getattr(args_cli, "headless", False):
+        return None
+    try:
+        return RdfUsdVisualDebugMarkers(point_size)
+    except Exception as usd_exc:
+        try:
+            logger.warning(f"[RDF] USD visual debug unavailable, falling back to debug draw: {usd_exc}")
+            return RdfDebugDrawMarkers(point_size)
+        except Exception as draw_exc:
+            logger.warning(f"[RDF] Visual debug disabled: unable to create marker renderer: {draw_exc}")
+            return None
+
