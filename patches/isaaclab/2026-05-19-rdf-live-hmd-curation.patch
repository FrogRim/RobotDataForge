+def compute_rdf_visual_targets(
+    env,
+    filtered_action: torch.Tensor,
+    applied_action: torch.Tensor,
+    input_display_scale: float,
+    control_metadata: dict | None = None,
+) -> dict[str, list[float]] | None:
+    """Compute viewport markers that separate hand intent from robot actuation."""
+
+    refresh_intermediate_values(env)
+    current_pos_value = getattr(env, "fingertip_midpoint_pos", None)
+    if current_pos_value is None:
+        return None
+
+    try:
+        current_pos = current_pos_value[0].to(device=applied_action.device, dtype=applied_action.dtype)
+        current = tensor_xyz_to_list(current_pos)
+        markers: dict[str, list[float]] = {"current": current}
+
+        if isinstance(control_metadata, dict) and control_metadata.get("name") in {
+            "operator_follow",
+            "bounded_direct_ee_target",
+        }:
+            operator_target = control_metadata.get("operator_target_xyz")
+            next_step_target = control_metadata.get("next_step_target_xyz")
+            if isinstance(operator_target, list) and len(operator_target) >= 3:
+                markers["hand_delta_target"] = [float(value) for value in operator_target[:3]]
+            if isinstance(next_step_target, list) and len(next_step_target) >= 3:
+                markers["applied_step_target"] = [float(value) for value in next_step_target[:3]]
+            if hasattr(env, "fixed_pos_obs_frame"):
+                fixed_pos = env.fixed_pos_obs_frame[0].to(device=applied_action.device, dtype=applied_action.dtype)
+                markers["forge_asset_target"] = tensor_xyz_to_list(fixed_pos)
+            return markers
+
+        if filtered_action.ndim == 1 and filtered_action.shape[0] >= 3:
+            hand_target = current_pos + filtered_action[0:3] * float(input_display_scale)
+            markers["hand_delta_target"] = tensor_xyz_to_list(hand_target)
+
+        if (
+            applied_action.ndim == 1
+            and applied_action.shape[0] >= 3
+            and all(
+                hasattr(env, attr)
+                for attr in (
+                    "fixed_pos_obs_frame",
+                    "init_fixed_pos_obs_noise",
+                    "pos_threshold",
+                    "cfg",
+                )
+            )
+            and hasattr(env.cfg, "ctrl")
+            and hasattr(env.cfg.ctrl, "pos_action_bounds")
+        ):
+            fixed_action_frame = (env.fixed_pos_obs_frame + env.init_fixed_pos_obs_noise)[0].to(
+                device=applied_action.device, dtype=applied_action.dtype
+            )
+            pos_bounds = torch.tensor(env.cfg.ctrl.pos_action_bounds, device=applied_action.device, dtype=applied_action.dtype)
+            desired_target = fixed_action_frame + applied_action[0:3] * pos_bounds
+            pos_threshold = env.pos_threshold[0].to(device=applied_action.device, dtype=applied_action.dtype)
+            applied_step_target = current_pos + torch.clamp(desired_target - current_pos, -pos_threshold, pos_threshold)
+            markers["applied_step_target"] = tensor_xyz_to_list(applied_step_target)
+            markers["forge_asset_target"] = tensor_xyz_to_list(desired_target)
+        elif applied_action.ndim == 1 and applied_action.shape[0] >= 3:
+            applied_step_target = current_pos + applied_action[0:3]
+            markers["applied_step_target"] = tensor_xyz_to_list(applied_step_target)
+
+        return markers
+    except Exception as exc:
+        logger.debug(f"[RDF] Visual target computation skipped: {exc}")
+        return None
+
+
+def draw_rdf_visual_targets(draw_interface, markers: dict[str, list[float]] | None, point_size: float) -> None:
+    if draw_interface is None or not markers:
+        return
+
+    colors = {
+        "current": [0.0, 1.0, 0.0, 1.0],
+        "hand_delta_target": [0.0, 0.85, 1.0, 1.0],
+        "applied_step_target": [1.0, 0.9, 0.0, 1.0],
+        "forge_asset_target": [1.0, 0.0, 1.0, 1.0],
+    }
+    ordered_keys = ["current", "hand_delta_target", "applied_step_target", "forge_asset_target"]
+    points = [markers[key] for key in ordered_keys if key in markers]
+    point_colors = [colors[key] for key in ordered_keys if key in markers]
+    point_sizes = [float(point_size)] * len(points)
+
+    try:
+        if hasattr(draw_interface, "clear_points"):
+            draw_interface.clear_points()
+        if points and hasattr(draw_interface, "draw_points"):
+            draw_interface.draw_points(points, point_colors, point_sizes)
+
+        if hasattr(draw_interface, "clear_lines"):
+            draw_interface.clear_lines()
+        current = markers.get("current")
+        target_keys = [key for key in ordered_keys if key != "current" and key in markers]
+        if current and target_keys and hasattr(draw_interface, "draw_lines"):
+            draw_interface.draw_lines(
+                [current] * len(target_keys),
+                [markers[key] for key in target_keys],
+                [colors[key] for key in target_keys],
+                [4.0] * len(target_keys),
+            )
+    except Exception as exc:
+        logger.debug(f"[RDF] Visual target draw skipped: {exc}")
+
