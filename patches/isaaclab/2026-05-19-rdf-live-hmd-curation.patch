+        parse_signed_axis_map = None
+        _rdf_insertion_task_state = None
+        _rdf_task_state_config = None
+
+
+def action_to_list(action: torch.Tensor) -> list[float]:
+    value = action
+    if hasattr(value, "detach"):
+        value = value.detach()
+    if hasattr(value, "cpu"):
+        value = value.cpu()
+    if hasattr(value, "tolist"):
+        data = value.tolist()
+    else:
+        data = value
+    if isinstance(data, (list, tuple)):
+        return [float(item) for item in data]
+    return [float(data)]
+
+
+def vector_norm(values: list[float]) -> float:
+    return float(torch.linalg.vector_norm(torch.tensor(values, dtype=torch.float32)).item()) if values else 0.0
+
+
+def list_to_action(values: list[float], reference: torch.Tensor) -> torch.Tensor:
+    return torch.tensor(values, dtype=reference.dtype, device=reference.device)
+
+
+def first_tensor_row_to_list(value, limit: int | None = None) -> list[float] | None:
+    try:
+        if hasattr(value, "detach"):
+            value = value.detach()
+        if hasattr(value, "ndim") and value.ndim > 1:
+            value = value[0]
+        if hasattr(value, "cpu"):
+            value = value.cpu()
+        if hasattr(value, "tolist"):
+            value = value.tolist()
+        if isinstance(value, (list, tuple)):
+            items = value[:limit] if limit is not None else value
+            return [float(item) for item in items]
+        return [float(value)]
+    except Exception:
+        return None
+
+
+def refresh_intermediate_values(env) -> None:
+    try:
+        robot = getattr(env, "_robot", None)
+        robot_data = getattr(robot, "_data", None)
+        sim_timestamp = getattr(robot_data, "_sim_timestamp", None)
+        last_update_timestamp = getattr(env, "last_update_timestamp", None)
+        if (
+            sim_timestamp is not None
+            and last_update_timestamp is not None
+            and last_update_timestamp < sim_timestamp
+            and hasattr(env, "_compute_intermediate_values")
+        ):
+            env._compute_intermediate_values(dt=getattr(env, "physics_dt", env.sim.get_physics_dt()))
+    except Exception:
+        return
+
+
+def fingertip_position_list(env) -> list[float] | None:
+    refresh_intermediate_values(env)
+    return first_tensor_row_to_list(getattr(env, "fingertip_midpoint_pos", None), limit=3)
+
+
+def is_forge_asset_relative_env(env, task_name: str | None) -> bool:
+    if task_name and "Isaac-Forge-" not in task_name:
+        return False
+    return all(
+        hasattr(env, attr)
+        for attr in (
+            "fingertip_midpoint_pos",
+            "fixed_pos_obs_frame",
+            "init_fixed_pos_obs_noise",
+            "actions",
+            "cfg",
+        )
+    )
+
+
+def is_factory_like_direct_env(env) -> bool:
+    return all(
+        hasattr(env, attr)
+        for attr in (
+            "fingertip_midpoint_pos",
+            "fingertip_midpoint_quat",
+            "generate_ctrl_signals",
+            "pos_threshold",
+            "rot_threshold",
+            "actions",
+        )
+    )
+
+
+def resolve_teleop_control_mode(env, task_name: str | None) -> str:
+    requested = args_cli.rdf_teleop_control_mode
+    if requested != "auto":
+        if requested == "direct_ee_target":
+            return "bounded_direct_ee_target"
+        return requested
+    if is_forge_asset_relative_env(env, task_name):
+        return "bounded_direct_ee_target"
+    return "native"
+
+
+def reset_cartesian_delta_control_state(env) -> None:
+    if hasattr(env, "actions"):
+        env.actions.zero_()
+    if hasattr(env, "prev_actions"):
+        env.prev_actions.zero_()
+    if hasattr(env, "pos_threshold"):
+        env.delta_pos = torch.zeros((env.num_envs, 3), device=env.device)
+    if hasattr(env, "rot_threshold"):
+        env.delta_yaw = torch.zeros((env.num_envs,), device=env.device)
+    if hasattr(env, "ema_factor"):
+        ema_value = max(0.0, min(1.0, float(args_cli.rdf_cartesian_delta_ema)))
+        if hasattr(env.ema_factor, "fill_"):
+            env.ema_factor.fill_(ema_value)
+        else:
+            env.ema_factor = ema_value
+    for attr in (
+        "rdf_direct_ee_target_pos",
+        "rdf_direct_ee_command_step",
+        "rdf_operator_follow_direct_target_pos",
+        "rdf_operator_follow_command_step",
+    ):
+        if hasattr(env, attr):
+            setattr(env, attr, None)
+
+
+def apply_cartesian_delta_action(env) -> None:
+    """Apply Factory current-fingertip delta control while preserving Forge reward fields."""
+
+    FactoryEnv._apply_action(env)
+    if hasattr(env, "actions") and hasattr(env, "pos_threshold"):
+        env.delta_pos = env.actions[:, 0:3] * env.pos_threshold
+    if hasattr(env, "actions") and hasattr(env, "rot_threshold") and env.actions.shape[-1] >= 6:
+        env.delta_yaw = env.actions[:, 5] * env.rot_threshold[:, 2]
+    elif hasattr(env, "rot_threshold"):
+        env.delta_yaw = torch.zeros((env.num_envs,), device=env.device)
+
+
+def apply_operator_follow_direct_action(env) -> None:
+    """Apply RDF live collection target control, not native policy action semantics."""
+
+    if getattr(env, "last_update_timestamp", 0.0) < env._robot._data._sim_timestamp:
+        env._compute_intermediate_values(dt=env.physics_dt)
+
+    target_pos = getattr(env, "rdf_direct_ee_target_pos", None)
+    if target_pos is None:
+        target_pos = getattr(env, "rdf_operator_follow_direct_target_pos", None)
+    if target_pos is None:
+        apply_cartesian_delta_action(env)
+        return
+
+    target_pos = target_pos.to(device=env.device, dtype=env.fingertip_midpoint_pos.dtype)
+    if target_pos.ndim == 1:
+        target_pos = target_pos.unsqueeze(0)
+    if target_pos.shape[0] != env.num_envs:
+        target_pos = target_pos[0:1].repeat(env.num_envs, 1)
+
+    env.delta_pos = target_pos - env.fingertip_midpoint_pos
+    if hasattr(env, "rot_threshold"):
+        env.delta_yaw = torch.zeros((env.num_envs,), device=env.device)
+
+    # For MVP-1 insertion collection, position following is the primary UX.
+    # Keep the current wrist orientation stable instead of reusing Forge policy yaw bounds.
+    env.generate_ctrl_signals(
+        ctrl_target_fingertip_midpoint_pos=target_pos,
+        ctrl_target_fingertip_midpoint_quat=env.fingertip_midpoint_quat,
+        ctrl_target_gripper_dof_pos=0.0,
+    )
+
+
+def enable_cartesian_delta_control(env) -> bool:
+    if not is_factory_like_direct_env(env):
+        return False
+    env._apply_action = MethodType(apply_cartesian_delta_action, env)
+    reset_cartesian_delta_control_state(env)
+    return True
+
+
+def enable_operator_follow_direct_control(env) -> bool:
+    if not is_factory_like_direct_env(env):
+        return False
+    env._apply_action = MethodType(apply_operator_follow_direct_action, env)
+    reset_cartesian_delta_control_state(env)
+    return True
+
+
+def enable_bounded_direct_ee_target_control(env) -> bool:
+    if not is_factory_like_direct_env(env):
+        return False
+    env._apply_action = MethodType(apply_operator_follow_direct_action, env)
+    reset_cartesian_delta_control_state(env)
+    return True
+
+
+def clamp_vector_norm(vector: torch.Tensor, max_norm: float) -> torch.Tensor:
+    if max_norm <= 0.0:
+        return torch.zeros_like(vector)
+    norm = torch.linalg.vector_norm(vector)
+    if float(norm.item()) <= max_norm:
+        return vector
+    return vector * (max_norm / (norm + 1.0e-9))
+
+
+def operator_follow_preset_defaults(preset: str) -> dict[str, float]:
+    if preset == "responsive":
+        return {
+            "workspace_gain": 0.12,
+            "max_step_m": 0.04,
+            "smoothing_alpha": 0.90,
+            "deadzone_m": 0.0002,
+            "workspace_radius_m": 0.25,
+        }
+    if preset == "fast":
+        return {
+            "workspace_gain": 0.06,
+            "max_step_m": 0.02,
+            "smoothing_alpha": 0.70,
+            "deadzone_m": 0.0003,
+            "workspace_radius_m": 0.12,
+        }
+    return {
+        "workspace_gain": 0.03,
+        "max_step_m": 0.01,
+        "smoothing_alpha": 0.35,
+        "deadzone_m": 0.0005,
+        "workspace_radius_m": 0.09,
+    }
+
+
+def resolved_operator_follow_config() -> dict[str, float | str]:
+    defaults = operator_follow_preset_defaults(args_cli.rdf_operator_follow_preset)
+
+    def override(name: str, value: float) -> float:
+        return float(defaults[name] if value < 0.0 else value)
+
+    return {
+        "preset": args_cli.rdf_operator_follow_preset,
+        "workspace_gain": max(0.0, override("workspace_gain", args_cli.rdf_operator_follow_workspace_gain)),
+        "max_step_m": max(0.0, override("max_step_m", args_cli.rdf_operator_follow_max_step_m)),
+        "smoothing_alpha": max(
+            0.0, min(1.0, override("smoothing_alpha", args_cli.rdf_operator_follow_smoothing_alpha))
+        ),
+        "deadzone_m": max(0.0, override("deadzone_m", args_cli.rdf_operator_follow_deadzone_m)),
+        "workspace_radius_m": max(0.0, override("workspace_radius_m", args_cli.rdf_operator_follow_workspace_radius_m)),
+    }
+
+
+def resolved_bounded_direct_ee_config() -> dict[str, float | str]:
+    return {
+        "preset": "bounded_direct_ee_target",
+        "workspace_gain": max(0.0, float(args_cli.rdf_direct_ee_pos_gain)),
+        "position_gain": max(0.0, float(args_cli.rdf_direct_ee_pos_gain)),
+        "rotation_gain": max(0.0, float(args_cli.rdf_direct_ee_rot_gain)),
+        "max_step_m": max(0.0, float(args_cli.rdf_direct_ee_max_step_m)),
+        "max_rot_step_rad": max(0.0, float(args_cli.rdf_direct_ee_max_rot_step_rad)),
+        "smoothing_alpha": max(0.0, min(1.0, float(args_cli.rdf_direct_ee_smoothing_alpha))),
+        "deadzone_m": max(0.0, float(args_cli.rdf_direct_ee_deadzone_m)),
+        "workspace_radius_m": max(0.0, float(args_cli.rdf_direct_ee_workspace_radius_m)),
+    }
+
+
+def teleop_right_wrist_pose_list(teleop_interface) -> list[float] | None:
+    try:
+        right_poses = getattr(teleop_interface, "_previous_joint_poses_right", {})
+        if not isinstance(right_poses, dict):
+            return None
+        wrist = right_poses.get("wrist")
+        values = first_tensor_row_to_list(wrist, limit=7)
+        return values if values and len(values) >= 3 else None
+    except Exception:
+        return None
+
+
+def rdf_pose_is_valid(pose: list[float] | None) -> bool:
+    if not pose or len(pose) < 3:
+        return False
+    try:
+        values = [float(value) for value in pose[:7]]
+    except Exception:
+        return False
+    if any(not math.isfinite(value) for value in values):
+        return False
+    return any(abs(value) > 1.0e-9 for value in values[:3])
+
+
+class RdfOperatorFollowController:
+    """Collection-first controller that follows a virtual operator workspace target."""
+
+    def __init__(
+        self,
+        config: dict[str, float | str],
+        *,
+        name: str = "operator_follow",
+        control_semantics: str = "operator_workspace_target_following",
+        target_env_attr: str = "rdf_operator_follow_direct_target_pos",
+    ):
+        self.config = config
+        self.name = name
+        self.control_semantics = control_semantics
+        self.target_env_attr = target_env_attr
+        self.command_env_attr = (
+            "rdf_direct_ee_command_step"
+            if target_env_attr == "rdf_direct_ee_target_pos"
+            else "rdf_operator_follow_command_step"
+        )
+        self._anchor_pos: torch.Tensor | None = None
+        self._target_pos: torch.Tensor | None = None
+        self._previous_step: torch.Tensor | None = None
+        self._reset_reason: str | None = None
+
+    def reset(self, env, reason: str, teleop_interface=None) -> None:
+        refresh_intermediate_values(env)
+        current = getattr(env, "fingertip_midpoint_pos", None)
+        if current is None:
+            self._anchor_pos = None
+            self._target_pos = None
+            self._previous_step = None
+            self._reset_reason = reason
+            return
+        current_pos = current[0].detach().clone()
+        self._anchor_pos = current_pos
+        self._target_pos = current_pos.clone()
+        self._previous_step = torch.zeros_like(current_pos)
+        self._reset_reason = reason
+
+    def apply(self, env, filtered_action: torch.Tensor, teleop_interface=None) -> tuple[torch.Tensor, dict]:
+        refresh_intermediate_values(env)
+        current_value = getattr(env, "fingertip_midpoint_pos", None)
+        if current_value is None:
+            return filtered_action, self.metadata([], [], [], [], [], [], [], 0.0, 0.0, False)
+
+        current_pos = current_value[0].to(device=filtered_action.device, dtype=filtered_action.dtype)
+        if (
+            self._anchor_pos is None
+            or self._target_pos is None
+            or self._previous_step is None
+            or self._target_pos.device != filtered_action.device
+        ):
+            self.reset(env, "auto_first_apply")
+
+        assert self._anchor_pos is not None
+        assert self._target_pos is not None
+        assert self._previous_step is not None
+        self._anchor_pos = self._anchor_pos.to(device=filtered_action.device, dtype=filtered_action.dtype)
+        self._target_pos = self._target_pos.to(device=filtered_action.device, dtype=filtered_action.dtype)
+        self._previous_step = self._previous_step.to(device=filtered_action.device, dtype=filtered_action.dtype)
+
+        input_delta = torch.zeros(3, device=filtered_action.device, dtype=filtered_action.dtype)
+        if filtered_action.ndim == 1 and filtered_action.shape[0] >= 3:
+            input_delta = filtered_action[0:3]
+
+        workspace_gain = float(self.config["workspace_gain"])
+        hand_delta_m = input_delta * workspace_gain
+        if float(torch.linalg.vector_norm(hand_delta_m).item()) < float(self.config["deadzone_m"]):
+            hand_delta_m = torch.zeros_like(hand_delta_m)
+
+        self._target_pos = self._target_pos + hand_delta_m
+        target_offset = self._target_pos - self._anchor_pos
+        unclamped_offset_norm = float(torch.linalg.vector_norm(target_offset).item())
+        clamped_offset = clamp_vector_norm(target_offset, float(self.config["workspace_radius_m"]))
+        workspace_clamped = unclamped_offset_norm > float(self.config["workspace_radius_m"]) + 1.0e-9
+        self._target_pos = self._anchor_pos + clamped_offset
+
+        error = self._target_pos - current_pos
+        raw_step = clamp_vector_norm(error, float(self.config["max_step_m"]))
+        alpha = float(self.config["smoothing_alpha"])
+        command_step = alpha * raw_step + (1.0 - alpha) * self._previous_step
+        command_step = clamp_vector_norm(command_step, float(self.config["max_step_m"]))
+        self._previous_step = command_step.detach().clone()
+
+        adapted_action = filtered_action.clone()
+        if adapted_action.ndim == 1 and adapted_action.shape[0] >= 3 and hasattr(env, "pos_threshold"):
+            pos_threshold = env.pos_threshold[0].to(device=filtered_action.device, dtype=filtered_action.dtype)
+            adapted_action[0:3] = torch.clamp(command_step / torch.clamp(pos_threshold, min=1.0e-6), -1.0, 1.0)
+        if adapted_action.ndim == 1 and adapted_action.shape[0] >= 6:
+            adapted_action[3:6] = torch.clamp(adapted_action[3:6], -1.0, 1.0)
+
+        next_target = current_pos + command_step
+        setattr(env, self.target_env_attr, next_target.detach().clone().unsqueeze(0))
+        setattr(env, self.command_env_attr, command_step.detach().clone().unsqueeze(0))
+        return adapted_action, self.metadata(
+            current_xyz=tensor_xyz_to_list(current_pos),
+            input_delta=tensor_xyz_to_list(input_delta),
+            hand_delta_m=tensor_xyz_to_list(hand_delta_m),
+            target_xyz=tensor_xyz_to_list(self._target_pos),
+            next_target_xyz=tensor_xyz_to_list(next_target),
+            command_step_xyz=tensor_xyz_to_list(command_step),
+            native_action=action_to_list(adapted_action),
+            target_error_norm=float(torch.linalg.vector_norm(error).item()),
+            command_step_norm=float(torch.linalg.vector_norm(command_step).item()),
+            workspace_clamped=workspace_clamped,
+            raw_right_wrist_pose=teleop_right_wrist_pose_list(teleop_interface) if teleop_interface is not None else None,
+        )
+
+    def metadata(
+        self,
+        current_xyz,
+        input_delta,
+        hand_delta_m,
+        target_xyz,
+        next_target_xyz,
+        command_step_xyz,
+        native_action,
+        target_error_norm: float,
+        command_step_norm: float,
+        workspace_clamped: bool,
+        raw_right_wrist_pose: list[float] | None = None,
+    ) -> dict:
+        rounded_step = [round(value, 5) for value in hand_delta_m]
+        rounded_command_step = [round(value, 5) for value in command_step_xyz]
+        rounded_target = [round(value, 5) for value in target_xyz]
+        rounded_next_target = [round(value, 5) for value in next_target_xyz]
+        rounded_current = [round(value, 5) for value in current_xyz]
+        return {
+            "name": self.name,
+            "preset": self.config["preset"],
+            "workspace_gain": self.config["workspace_gain"],
+            "position_gain": self.config.get("position_gain", self.config["workspace_gain"]),
+            "rotation_gain": self.config.get("rotation_gain", 0.0),
+            "max_step_m": self.config["max_step_m"],
+            "max_rot_step_rad": self.config.get("max_rot_step_rad", 0.0),
+            "smoothing_alpha": self.config["smoothing_alpha"],
+            "deadzone_m": self.config["deadzone_m"],
+            "workspace_radius_m": self.config["workspace_radius_m"],
+            "control_semantics": self.control_semantics,
+            "direct_control_apply": True,
+            "input_delta_xyz": [round(value, 5) for value in input_delta],
+            "hand_delta_m": rounded_step,
+            "applied_ee_delta_m": rounded_command_step,
+            "operator_target_xyz": rounded_target,
+            "desired_ee_target_xyz": rounded_target,
+            "next_step_target_xyz": rounded_next_target,
+            "actual_ee_xyz": rounded_current,
+            "desired_end_effector_pose": {
+                "position": rounded_target,
+                "quaternion": None,
+                "frame": "isaac_world",
+                "source": "recentered_hand_target",
+            },
+            "applied_end_effector_action": {
+                "delta_position": rounded_command_step,
+                "delta_rotation": [0.0, 0.0, 0.0],
+                "frame": "isaac_world",
+            },
+            "native_isaac_action": [round(value, 6) for value in native_action],
+            "raw_right_wrist_pose": raw_right_wrist_pose,
+            "action_contract_version": RDF_ACTION_CONTRACT_VERSION,
+            "replay_contract_version": RDF_REPLAY_CONTRACT_VERSION,
+            "target_error_norm": round(float(target_error_norm), 6),
+            "command_step_norm": round(float(command_step_norm), 6),
+            "workspace_clamped": bool(workspace_clamped),
+            "last_reset_reason": self._reset_reason,
+        }
+
+
+class RdfBoundedDirectEeTargetController(RdfOperatorFollowController):
+    """MVP-1 primary collection UX: bounded hand target to end-effector target servo."""
+
+    def __init__(self, config: dict[str, float | str]):
+        super().__init__(
+            config,
+            name="bounded_direct_ee_target",
+            control_semantics="bounded_direct_end_effector_target_servo",
+            target_env_attr="rdf_direct_ee_target_pos",
+        )
+
+
+def adapt_cartesian_delta_action(action: torch.Tensor) -> tuple[torch.Tensor, dict]:
+    adapted_action = action.clone()
+    if adapted_action.ndim == 1 and adapted_action.shape[0] >= 3:
+        adapted_action[0:3] = torch.clamp(adapted_action[0:3] * args_cli.rdf_cartesian_delta_pos_gain, -1.0, 1.0)
+    if adapted_action.ndim == 1 and adapted_action.shape[0] >= 6:
+        adapted_action[3:6] = torch.clamp(adapted_action[3:6] * args_cli.rdf_cartesian_delta_rot_gain, -1.0, 1.0)
+    return adapted_action, {
+        "name": "factory_cartesian_delta_control",
+        "position_gain": args_cli.rdf_cartesian_delta_pos_gain,
+        "rotation_gain": args_cli.rdf_cartesian_delta_rot_gain,
+        "ema_factor": args_cli.rdf_cartesian_delta_ema,
+        "control_semantics": "current_fingertip_delta",
+    }
+
+
+def adapt_forge_asset_relative_action(env, teleop_delta_action: torch.Tensor) -> tuple[torch.Tensor, dict | None]:
+    """Map relative SE(3) teleop deltas to Forge direct asset-relative action targets.
+
+    Forge direct insertion tasks interpret actions as normalized target pose values
+    relative to the fixed asset. OpenXR SE(3) retargeters emit relative deltas.
+    This adapter preserves the direct task while making live hand motion behave
+    like "move from the current fingertip pose by this small delta".
+    """
+
+    refresh_intermediate_values(env)
+    if not all(
+        hasattr(env, attr)
+        for attr in (
+            "fingertip_midpoint_pos",
+            "fixed_pos_obs_frame",
+            "init_fixed_pos_obs_noise",
+            "pos_threshold",
+            "rot_threshold",
+            "actions",
+        )
+    ):
+        return teleop_delta_action, None
+
+    if teleop_delta_action.ndim != 1 or teleop_delta_action.shape[0] < 7:
+        return teleop_delta_action, None
+
+    device = teleop_delta_action.device
+    dtype = teleop_delta_action.dtype
+    adapted_action = teleop_delta_action.clone()
+
+    fingertip_pos = env.fingertip_midpoint_pos[0].to(device=device, dtype=dtype)
+    fixed_action_frame = (env.fixed_pos_obs_frame + env.init_fixed_pos_obs_noise)[0].to(device=device, dtype=dtype)
+    pos_threshold = env.pos_threshold[0].to(device=device, dtype=dtype)
+    pos_bounds = torch.tensor(env.cfg.ctrl.pos_action_bounds, device=device, dtype=dtype)
+
+    target_pos = fingertip_pos + teleop_delta_action[0:3] * pos_threshold
+    adapted_xyz = torch.clamp((target_pos - fixed_action_frame) / pos_bounds, -1.0, 1.0)
+    adapted_action[0:3] = adapted_xyz
+
+    current_env_action = env.actions[0].to(device=device, dtype=dtype)
