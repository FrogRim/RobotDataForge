+class RdfDebugDrawMarkers:
+    """Fallback marker renderer for non-XR viewport debug draw."""
+
+    def __init__(self, point_size: float):
+        import isaacsim.util.debug_draw._debug_draw as omni_debug_draw
+
+        self._draw_interface = omni_debug_draw.acquire_debug_draw_interface()
+        self._point_size = float(point_size)
+
+    def draw(self, markers: dict[str, list[float]] | None) -> None:
+        draw_rdf_visual_targets(self._draw_interface, markers, self._point_size)
+
