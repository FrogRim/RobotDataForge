+            sphere.CreateRadiusAttr(self._radius)
+            sphere.CreateDisplayColorAttr(self._colors[name])
+            xformable = UsdGeom.Xformable(sphere.GetPrim())
+            self._ops[name] = xformable.AddTranslateOp()
+
+    def draw(self, markers: dict[str, list[float]] | None) -> None:
+        if not markers:
+            return
+        for name, op in self._ops.items():
+            point = markers.get(name)
+            if point is None:
+                continue
+            op.Set(self._gf.Vec3d(float(point[0]), float(point[1]), float(point[2])))
+
