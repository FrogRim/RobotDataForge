+def normalize_quat_wxyz(quat: tuple[float, float, float, float]) -> tuple[float, float, float, float]:
+    norm = math.sqrt(sum(value * value for value in quat))
+    if norm <= 1.0e-12:
+        return (1.0, 0.0, 0.0, 0.0)
+    return tuple(value / norm for value in quat)
+
+
+def multiply_quat_wxyz(
+    lhs: tuple[float, float, float, float], rhs: tuple[float, float, float, float]
+) -> tuple[float, float, float, float]:
+    lw, lx, ly, lz = lhs
+    rw, rx, ry, rz = rhs
+    return normalize_quat_wxyz(
+        (
+            lw * rw - lx * rx - ly * ry - lz * rz,
+            lw * rx + lx * rw + ly * rz - lz * ry,
+            lw * ry - lx * rz + ly * rw + lz * rx,
+            lw * rz + lx * ry - ly * rx + lz * rw,
+        )
+    )
+
+
+def yaw_quat_wxyz(yaw_deg: float) -> tuple[float, float, float, float]:
+    half_rad = math.radians(yaw_deg) * 0.5
+    return (math.cos(half_rad), 0.0, 0.0, math.sin(half_rad))
+
+
+def configured_xr_anchor() -> tuple[tuple[float, float, float], tuple[float, float, float, float]]:
+    default_pos = (-0.1, -0.5, -1.05)
+    default_rot = (0.866, 0.0, 0.0, -0.5)
+    anchor_pos = parse_float_tuple(args_cli.rdf_xr_anchor_pos, 3, default_pos)
+    anchor_rot = normalize_quat_wxyz(parse_float_tuple(args_cli.rdf_xr_anchor_rot, 4, default_rot))
+    if abs(args_cli.rdf_xr_anchor_yaw_offset_deg) > 1.0e-9:
+        anchor_rot = multiply_quat_wxyz(yaw_quat_wxyz(args_cli.rdf_xr_anchor_yaw_offset_deg), anchor_rot)
+    return anchor_pos, anchor_rot
+
+
+def default_xr_cfg(env_cfg: ManagerBasedRLEnvCfg | DirectRLEnvCfg) -> XrCfg:
+    xr_cfg = getattr(env_cfg, "xr", None)
+    if xr_cfg is None:
+        anchor_pos, anchor_rot = configured_xr_anchor()
+        xr_cfg = XrCfg(anchor_pos=anchor_pos, anchor_rot=anchor_rot)
+        print(
+            "[RDF] XR anchor config: "
+            f"pos={tuple(round(value, 4) for value in anchor_pos)} "
+            f"rot={tuple(round(value, 4) for value in anchor_rot)} "
+            f"yaw_offset_deg={args_cli.rdf_xr_anchor_yaw_offset_deg:.2f}"
+        )
+        try:
+            env_cfg.xr = xr_cfg
+        except Exception:
+            pass
+    return xr_cfg
+
+
+def default_handtracking_devices_cfg(env_cfg: ManagerBasedRLEnvCfg | DirectRLEnvCfg) -> DevicesCfg:
+    action_dim = action_dimension_from_cfg(env_cfg)
+    retargeters = [
+        Se3RelRetargeterCfg(
+            bound_hand=DeviceBase.TrackingTarget.HAND_RIGHT,
+            zero_out_xy_rotation=True,
